{
    "window.zoomLevel": 1,
    "github.copilot.nextEditSuggestions.enabled": true,
    "csharp.inlayHints.enableInlayHintsForTypes": true,
    "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": true,
    "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": true,
    "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": true,
    "chat.viewSessions.orientation": "stacked",
    "workbench.colorTheme": "One Dark Pro Night Flat",
    "editor.lineNumbers": "relative",
    "editor.smoothScrolling": true,
    "editor.formatOnSave": true,
    "editor.editContext": false,
    "editor.experimentalEditContextEnabled": false,
    "workbench.list.smoothScrolling": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "always"
    },
    // vim settings
    "vim.useSystemClipboard": true,
    "vim.easymotion": true,
    "vim.statusBarColorControl": true, // モードごとの色制御を有効化
    "vim.useCtrlKeys": true,
    "vim.visualstar": true,
    "vim.hlsearch": true,
    "vim.leader": "<space>",
    "vim.handleKeys": {
        "<C-j>": true,
        "<C-k>": true,
    },
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        },
        {
            "before": [
                "<C-h>"
            ],
            "after": [
                "<Left>"
            ]
        },
        {
            "before": [
                "<C-j>"
            ],
            "after": [
                "<Down>"
            ]
        },
        {
            "before": [
                "<C-k>"
            ],
            "after": [
                "<Up>"
            ]
        },
        {
            "before": [
                "<C-l>"
            ],
            "after": [
                "<Right>"
            ]
        },
        {
            "before": [
                ";",
                ";"
            ],
            "commands": [
                "editor.action.triggerSuggest"
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "t"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "f"
            ]
        },
        {
            "before": [
                "T"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "F"
            ]
        },
        {
            "before": [
                "<leader>",
                "l",
                "l"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "<leader>",
                "l",
                "a"
            ],
            "commands": [
                "workbench.action.showErrorsWarnings"
            ],
        },
        {
            "before": [
                "<leader>",
                "t"
            ],
            "commands": [
                "workbench.action.terminal.toggleTerminal"
            ]
        },
        {
            "before": [
                "<leader>",
                "s"
            ],
            "commands": [
                "workbench.action.splitEditorDown"
            ]
        },
        {
            "before": [
                "<leader>",
                "v"
            ],
            "commands": [
                "workbench.action.splitEditorRight"
            ]
        },
        {
            "before": [
                "<leader>",
                "b"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "o"
            ],
            "commands": [
                "workbench.view.explorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "j"
            ],
            "commands": [
                "workbench.action.togglePanel"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            "commands": [
                "workbench.action.chat.open"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "g"
            ],
            "commands": [
                {
                    "command": "workbench.action.chat.open",
                    "args": {
                        "query": "/add-comment"
                    }
                }
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "p"
            ],
            "commands": [
                {
                    "command": "workbench.action.chat.open",
                    "args": {
                        "query": "/profread-tex"
                    }
                }
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "i",
            ],
            "commands": [
                "inlineChat.start"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "q"
            ],
            "commands": [
                "workbench.action.toggleAuxiliaryBar"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "w"
            ],
            "commands": [
                "workbench.action.closeAllEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "a"
            ],
            "commands": [
                "workbench.action.closeAllEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "p"
            ],
            "commands": [
                "workbench.action.pinEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "u"
            ],
            "commands": [
                "workbench.action.unpinEditor"
            ]
        },
        {
            "before": [
                "<C-w>",
            ],
            "commands": [
                "workbench.action.closeActiveEditor"
            ]
        },
        {
            "before": [
                "<C-h>"
            ],
            "commands": [
                "workbench.action.previousEditor"
            ]
        },
        {
            "before": [
                "<C-l>"
            ],
            "commands": [
                "workbench.action.nextEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "h"
            ],
            "commands": [
                "workbench.action.navigateLeft"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "l"
            ],
            "commands": [
                "workbench.action.navigateRight"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "j"
            ],
            "commands": [
                "workbench.action.navigateDown"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "k"
            ],
            "commands": [
                "workbench.action.navigateUp"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "w",
                "h"
            ],
            "commands": [
                "workbench.action.moveEditorToLeftGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "w",
                "l"
            ],
            "commands": [
                "workbench.action.moveEditorToRightGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "w",
                "k"
            ],
            "commands": [
                "workbench.action.moveEditorToAboveGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "m",
                "w",
                "j"
            ],
            "commands": [
                "workbench.action.moveEditorToBelowGroup"
            ]
        },
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "t"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "f"
            ]
        },
        {
            "before": [
                "T"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "F"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "i"
            ],
            "commands": [
                "inlineChat.start"
            ]
        },
    ],
    "vim.statusBarColors.normal": "#7d7d7d",
    "vim.statusBarColors.insert": "#446ac4",
    "vim.statusBarColors.visual": "#ceb244",
    "vim.statusBarColors.replace": "#B46378",
    "vim.statusBarColors.commandlineinprogress": "#a947c2",
    "vim.statusBarColors.easymotioninputmode": "#75a149",
    "vim.statusBarColors.easymotionmode": "#75a149",
    // Ctrlキーの組み合わせをすべてVimに処理させる
    "workbench.colorCustomizations": {
        "statusBar.background": "#7d7d7d",
        "statusBar.noFolderBackground": "#7d7d7d",
        "statusBar.debuggingBackground": "#7d7d7d",
        "statusBar.foreground": "#ffffff",
        "statusBar.debuggingForeground": "#ffffff"
    },
    "workbench.activityBar.compact": true,
    "editor.renderWhitespace": "trailing",
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "notebook.insertFinalNewline": true,
    "files.insertFinalNewline": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "editor.wordWrap": "on",
    "editor.minimap.enabled": false,
    "hediet.vscode-drawio.resizeImages": null
}
