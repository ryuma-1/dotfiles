{
    "window.zoomLevel": 1,
    "github.copilot.nextEditSuggestions.enabled": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "csharp.inlayHints.enableInlayHintsForTypes": true,
    "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": true,
    "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": true,
    "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": true,
    "chat.viewSessions.orientation": "stacked",
    "workbench.colorTheme": "One Dark Pro",
    "editor.lineNumbers": "relative",
    "editor.smoothScrolling": true,
    "editor.formatOnSave": true,
    "editor.editContext": false,
    "editor.experimentalEditContextEnabled": false,
    "workbench.list.smoothScrolling": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "always"
    },
    // vim settings
    "vim.useSystemClipboard": true,
    "vim.easymotion": true,
    "vim.statusBarColorControl": true, // モードごとの色制御を有効化
    "vim.useCtrlKeys": true,
    "vim.visualstar": true,
    "vim.hlsearch": true,
    "vim.leader": "<space>",
    "vim.handleKeys": {
        "<C-j>": true,
        "<C-k>": true,
    },
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        },
        {
            "before": [
                "<C-h>",
            ],
            "after": [
                "<Left>"
            ]
        },
        {
            "before": [
                "<C-l>"
            ],
            "after": [
                "<Right>"
            ]
        },
        {
            "before": [
                "<C-j>"
            ],
            "after": [
                "<C-o>",
                "g",
                "j"
            ]
        },
        {
            "before": [
                "<C-k>"
            ],
            "after": [
                "<C-o>",
                "g",
                "k"
            ]
        },
        {
            "before": [
                ";",
                ";"
            ],
            "commands": [
                "editor.action.triggerSuggest"
            ]
        },
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<Enter>"
            ],
            "commands": [
                "editor.action.insertLineAfter"
            ]
        },
        {
            "before": [
                "j"
            ],
            "after": [
                "g",
                "j"
            ]
        },
        {
            "before": [
                "k"
            ],
            "after": [
                "g",
                "k"
            ]
        },
        {
            "before": [
                "t"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "f"
            ]
        },
        {
            "before": [
                "T"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "F"
            ]
        },
        {
            "before": [
                "<leader>",
                "l",
                "l"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "<leader>",
                "l",
                "a"
            ],
            "commands": [
                "workbench.action.showErrorsWarnings"
            ],
        },
        {
            "before": [
                "<leader>",
                "t"
            ],
            "commands": [
                "workbench.action.terminal.toggleTerminal"
            ]
        },
        {
            "before": [
                "<leader>",
                "s"
            ],
            "commands": [
                "workbench.action.splitEditorDown"
            ]
        },
        {
            "before": [
                "<leader>",
                "v"
            ],
            "commands": [
                "workbench.action.splitEditorRight"
            ]
        },
        {
            "before": [
                "<leader>",
                "b"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "f"
            ],
            "commands": [
                "workbench.action.findInFiles"
            ]
        },
        {
            "before": [
                "<leader>",
                "e"
            ],
            "commands": [
                "workbench.view.explorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "g"
            ],
            "commands": [
                "workbench.view.scm"
            ]
        },
        {
            "before": [
                "<leader>",
                "x"
            ],
            "commands": [
                "workbench.view.extensions"
            ]
        },
        {
            "before": [
                "<leader>",
                "o"
            ],
            "commands": [
                "workbench.view.explorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "j"
            ],
            "commands": [
                "workbench.action.togglePanel"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            "commands": [
                "workbench.action.chat.open"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "g"
            ],
            "commands": [
                {
                    "command": "workbench.action.chat.open",
                    "args": {
                        "query": "/add-comment"
                    }
                }
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "p"
            ],
            "commands": [
                {
                    "command": "workbench.action.chat.open",
                    "args": {
                        "query": "/profread-tex"
                    }
                }
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "i",
            ],
            "commands": [
                "inlineChat.start"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "q"
            ],
            "commands": [
                "workbench.action.toggleAuxiliaryBar"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "w"
            ],
            "commands": [
                "workbench.action.closeAllEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "a"
            ],
            "commands": [
                "workbench.action.closeAllEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "o"
            ],
            "commands": [
                "workbench.action.closeOtherEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "g"
            ],
            "commands": [
                "workbench.action.closeEditorsInGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "p"
            ],
            "commands": [
                "workbench.action.pinEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "w",
                "u"
            ],
            "commands": [
                "workbench.action.unpinEditor"
            ]
        },
        {
            "before": [
                "g",
                "r"
            ],
            "commands": [
                "editor.action.goToReferences"
            ]
        },
        {
            "before": [
                "g",
                "n"
            ],
            "commands": [
                "editor.action.rename"
            ]
        },
        {
            "before": [
                "g",
                "a"
            ],
            "commands": [
                "editor.action.quickFix"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "t"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "f"
            ]
        },
        {
            "before": [
                "T"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "F"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "i"
            ],
            "commands": [
                "inlineChat.start"
            ]
        },
    ],
    "vim.statusBarColors.normal": "#7d7d7d",
    "vim.statusBarColors.insert": "#446ac4",
    "vim.statusBarColors.visual": "#ceb244",
    "vim.statusBarColors.replace": "#B46378",
    "vim.statusBarColors.commandlineinprogress": "#a947c2",
    "vim.statusBarColors.easymotioninputmode": "#75a149",
    "vim.statusBarColors.easymotionmode": "#75a149",
    // Ctrlキーの組み合わせをすべてVimに処理させる
    "workbench.colorCustomizations": {
        "editor.background": "#09070e",
        "statusBar.background": "#7d7d7d",
        "statusBar.noFolderBackground": "#7d7d7d",
        "statusBar.debuggingBackground": "#7d7d7d",
        "statusBar.foreground": "#ffffff",
        "statusBar.debuggingForeground": "#ffffff",
        "editorIndentGuide.activeBackground1": "#f0f0f0"
    },
    "workbench.activityBar.compact": true,
    "editor.renderWhitespace": "trailing",
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "notebook.insertFinalNewline": true,
    "files.insertFinalNewline": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "editor.wordWrap": "on",
    "editor.minimap.enabled": false,
    "hediet.vscode-drawio.resizeImages": null,
    "window.restoreWindows": "one",
    "extensions.ignoreRecommendations": true,
}
