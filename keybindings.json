// Place your key bindings in this file to override the defaults
[
    // ==========================================
    // 1. エディタ・UIの基本操作
    // ==========================================
    {
        "key": "escape",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "terminalFocus || ((chatInputFocus || inChat) && !inlineChatVisible) || sideBarFocus || panelFocus"
    },
    {
        "key": "ctrl+w",
        "command": "workbench.action.closeActiveEditor"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.previousEditor",
        "when": "vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.nextEditor",
        "when": "vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.moveEditorLeftInGroup",
        "when": "vim.mode != 'Insert'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.moveEditorRightInGroup",
        "when": "vim.mode != 'Insert'"
    },
    // ==========================================
    // 2. タブグループ（画面分割）間のフォーカス移動
    // ==========================================
    {
        "key": "alt+h",
        "mac": "option+h",
        "command": "workbench.action.navigateLeft"
    },
    {
        "key": "alt+l",
        "mac": "option+l",
        "command": "workbench.action.navigateRight"
    },
    {
        "key": "alt+j",
        "mac": "option+j",
        "command": "workbench.action.navigateDown"
    },
    {
        "key": "alt+k",
        "mac": "option+k",
        "command": "workbench.action.navigateUp"
    },
    // ==========================================
    // 3. 現在のタブを隣のグループへ移動
    // ==========================================
    {
        "key": "ctrl+alt+h",
        "mac": "ctrl+option+h",
        "command": "workbench.action.moveEditorToLeftGroup"
    },
    {
        "key": "ctrl+alt+l",
        "mac": "ctrl+option+l",
        "command": "workbench.action.moveEditorToRightGroup"
    },
    {
        "key": "ctrl+alt+k",
        "mac": "ctrl+option+k",
        "command": "workbench.action.moveEditorToAboveGroup"
    },
    {
        "key": "ctrl+alt+j",
        "mac": "ctrl+option+j",
        "command": "workbench.action.moveEditorToBelowGroup"
    },
    // ==========================================
    // 4. コードの行移動 (Vim ノーマルモード専用)
    // ==========================================
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 5. GitHub Copilot: インラインサジェストの受け入れ
    // ==========================================
    // ① 提案が出ている時は Ctrl+Enter で一括受け入れ
    {
        "key": "ctrl+enter",
        "command": "editor.action.inlineSuggest.commit",
        "when": "inlineSuggestionVisible || inlineEditIsVisible || inInlineEditsPreviewEditor"
    },
    // ② 次の編集提案 (Next Edit Suggestion) がある場合の受け入れ
    {
        "key": "ctrl+enter",
        "command": "github.copilot.nextEditSuggestions.accept",
        "when": "editorTextFocus && github.copilot.nextEditSuggestions.hasSuggestions"
    },
    // ③ 単語（部分）ごとの受け入れ
    {
        "key": "alt+l",
        "command": "editor.action.inlineSuggest.acceptNextWord",
        "when": "inlineSuggestionVisible && editorTextFocus"
    },
    // ④ 標準の Tab キーによる提案受け入れを完全に無効化
    {
        "key": "tab",
        "command": "-editor.action.inlineSuggest.commit"
    },
    // ==========================================
    // 6. GitHub Copilot: チャットの送信設定
    // ==========================================
    {
        "key": "ctrl+enter",
        "command": "workbench.action.chat.submit",
        "when": "inChatInput"
    },
    {
        "key": "enter",
        "command": "-workbench.action.chat.submit",
        "when": "chatInputHasText && chatSessionOptionsValid && inChatInput && !chatSessionRequestInProgress && !withinEditSessionDiff || chatInputHasText && chatSessionOptionsValid && inChatInput && !withinEditSessionDiff && chatEditingSentRequest == 's'"
    },
    // ==========================================
    // 7. shift を交えた vim のコマンドの設定
    // ==========================================
    {
        "key": "shift+enter",
        "command": "editor.action.insertLineBefore",
        "when": "editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 8. Markdown All in One x VSCode Vim 連携
    // ==========================================
    // インサートモードでのTab/Shift+TabをMarkdown All in Oneのリスト操作として確実に発火させる
    {
        "key": "tab",
        "command": "markdown.extension.onTabKey",
        "when": "editorLangId == 'markdown' && editorTextFocus && !suggestWidgetVisible && vim.mode == 'Insert'"
    },
    {
        "key": "shift+tab",
        "command": "markdown.extension.onShiftTabKey",
        "when": "editorLangId == 'markdown' && editorTextFocus && !suggestWidgetVisible && vim.mode == 'Insert'"
    },
    // ノーマル/ビジュアルモードでもTabキーを使って Markdown All in One 基準のリストインデントができるようにする
    {
        "key": "tab",
        "command": "markdown.extension.onTabKey",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.mode != 'Insert'"
    },
    {
        "key": "shift+tab",
        "command": "markdown.extension.onShiftTabKey",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.mode != 'Insert'"
    },
    // ==========================================
    // 9. Markdown: m b でボールド化 (Visual / Normal)
    // ==========================================
    {
        "key": "m b",
        "command": "markdown.extension.editing.toggleBold",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    // ついでにノーマルモードでも現在の単語をボールド化できるようにすると便利です
    {
        "key": "m b",
        "command": "markdown.extension.editing.toggleBold",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 10. Markdown: m i でイタリック化 (Visual / Normal)
    // ==========================================
    {
        "key": "m i",
        "command": "markdown.extension.editing.toggleItalic",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m i",
        "command": "markdown.extension.editing.toggleItalic",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 11. Markdown: m s で取り消し線 (Visual / Normal)
    // ==========================================
    {
        "key": "m s",
        "command": "markdown.extension.editing.toggleStrikethrough",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m s",
        "command": "markdown.extension.editing.toggleStrikethrough",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 12. Markdown: m m で数式化 (Visual / Normal)
    // ==========================================
    {
        "key": "m m",
        "command": "markdown.extension.editing.toggleMath",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m m",
        "command": "markdown.extension.editing.toggleMath",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 13. Markdown: Markdown All in One を使った行移動 (Normal)
    // ==========================================
    {
        "key": "alt+j",
        "command": "markdown.extension.onMoveLineDown",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    {
        "key": "alt+k",
        "command": "markdown.extension.onMoveLineUp",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 14. Markdown: Markdown All in One を使った複数行移動 (Visual)
    // ==========================================
    {
        "key": "alt+j",
        "command": "markdown.extension.onMoveLineDown",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "alt+k",
        "command": "markdown.extension.onMoveLineUp",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    // ==========================================
    // 15. Markdown: m c でタスクリストのチェックをトグル (Visual / Normal)
    // ==========================================
    {
        "key": "m c",
        "command": "markdown.extension.checkTaskList",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m c",
        "command": "markdown.extension.checkTaskList",
        "when": "editorLangId == 'markdown' && editorTextFocus && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 16. Markdown: m v v でプレビューを開く (Visual / Normal)
    // ==========================================
    {
        "key": "m v v",
        "command": "markdown.showPreview",
        "when": "editorLangId == 'markdown' && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m v v",
        "command": "markdown.showPreview",
        "when": "editorLangId == 'markdown' && vim.active && vim.mode == 'Normal'"
    },
    // ==========================================
    // 17. Markdown: m v k でプレビューを横に開く (Visual / Normal)
    // ==========================================
    {
        "key": "m v k",
        "command": "markdown.showPreviewToSide",
        "when": "editorLangId == 'markdown' && vim.active && vim.mode == 'Visual'"
    },
    {
        "key": "m v k",
        "command": "markdown.showPreviewToSide",
        "when": "editorLangId == 'markdown' && vim.active && vim.mode == 'Normal'"
    }
]
